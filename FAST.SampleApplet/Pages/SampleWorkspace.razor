@page "/sample"
@page "/sample/{NodeId}"
@using FAST.Matrix.Contracts.UI
@using FAST.Matrix.Contracts.Overlay
@using FAST.SampleApplet.Applet
@using FAST.SampleApplet.Models
@inject SampleApplet Applet
@inject IShellUiContext ShellUi
@inject IShellAppletContext AppletContext
@inject IFastOverlayOrchestrator Overlay
@implements IDisposable

<PageTitle>Sample Applet — @(Applet.CurrentNode?.Text ?? "No Selection")</PageTitle>

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="@(Applet.CurrentNode?.IconClass ?? "fas fa-circle") mr-2"></i>
                    @if (Applet.CurrentNode is null)
                    {
                        <span class="text-muted">Select a node from the sidebar tree</span>
                    }
                    else
                    {
                        @Applet.CurrentNode.Text
                        <span class="badge badge-secondary ml-2">@Applet.CurrentNode.NodeType</span>
                    }
                </h3>
                @if (_isDirty)
                {
                    <div class="card-tools">
                        <span class="badge badge-warning">
                            <i class="fas fa-exclamation-triangle mr-1"></i>Unsaved Changes
                        </span>
                    </div>
                }
            </div>

            @if (Applet.CurrentNode?.NodeType == "Office")
            {
                <div class="card-body">
                    <div class="form-group">
                        <label>Office Name</label>
                        <input class="form-control"
                               value="@_officeName"
                               @oninput="e => { _officeName = e.Value?.ToString() ?? string.Empty; SetDirty(); }" />
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        <input class="form-control"
                               value="@_address"
                               @oninput="e => { _address = e.Value?.ToString() ?? string.Empty; SetDirty(); }" />
                    </div>
                    <div class="form-group">
                        <label>Notes</label>
                        <textarea class="form-control" rows="3"
                                  @oninput="e => { _notes = e.Value?.ToString() ?? string.Empty; SetDirty(); }">@_notes</textarea>
                    </div>
                    <div class="mt-3">
                        <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                            <i class="fas fa-save mr-1"></i> Save
                        </button>
                        <button class="btn btn-info btn-sm ml-2" @onclick="LinkFileAsync">
                            <i class="fas fa-folder-open mr-1"></i> Link File
                        </button>
                        @if (!string.IsNullOrEmpty(_linkedFile))
                        {
                            <span class="ml-3 text-muted">
                                <i class="fas fa-paperclip mr-1"></i>@_linkedFile
                            </span>
                        }
                    </div>
                </div>
            }
            else if (Applet.CurrentNode is not null)
            {
                <div class="card-body text-muted">
                    <i class="fas fa-info-circle mr-1"></i>
                    Select an <strong>Office</strong> node to open its edit form.
                </div>
            }
            else
            {
                <div class="card-body">
                    <div class="fast-loading" style="min-height:120px;">
                        <i class="fas fa-mouse-pointer fa-2x text-muted"></i>
                        <p class="text-muted mt-2">Click any node in the sidebar to begin.</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-primary elevation-1"><i class="fas fa-layer-group"></i></span>
            <div class="info-box-content"><span class="info-box-text">Groups</span><span class="info-box-number">2</span></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-info elevation-1"><i class="fas fa-building"></i></span>
            <div class="info-box-content"><span class="info-box-text">Companies</span><span class="info-box-number">3</span></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-success elevation-1"><i class="fas fa-map-marker-alt"></i></span>
            <div class="info-box-content"><span class="info-box-text">Offices</span><span class="info-box-number">5</span></div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? NodeId { get; set; }

    private string _previousNodeId = string.Empty;
    private bool   _isDirty;
    private string _officeName = string.Empty;
    private string _address    = string.Empty;
    private string _notes      = string.Empty;
    private string _linkedFile = string.Empty;

    protected override void OnInitialized()
    {
        // Applet is already active (activated by AppletActivationService via router).
        // Just register ourselves as the active applet context.
        AppletContext.SetActiveApplet(Applet);

        // Subscribe to shell state changes to update form when a node is selected.
        ShellUi.OnStateChanged += HandleShellStateChanged;
    }

    private void HandleShellStateChanged()
    {
        var node   = Applet.CurrentNode;
        var nodeId = node?.Id ?? string.Empty;

        if (nodeId == _previousNodeId) return;

        _previousNodeId = nodeId;

        if (node?.NodeType == "Office")
        {
            _officeName = node.Text;
            _address    = node.Metadata.GetValueOrDefault("address", string.Empty);
            _notes      = string.Empty;
            _isDirty    = false;
            Applet.MarkClean();
        }
        else
        {
            _officeName = _address = _notes = string.Empty;
            _isDirty    = false;
        }

        InvokeAsync(StateHasChanged);
    }

    private void SetDirty() { _isDirty = true; Applet.MarkDirty(); }

    private async Task SaveAsync()
    {
        await Task.Delay(150);
        _isDirty = false;
        Applet.MarkClean();
        StateHasChanged();
    }

    private async Task LinkFileAsync()
    {
        var result = await Overlay.InvokeFileManagerAsync(new FileManagerConfiguration
        {
            PanelTitle       = "Select Office Document",
            AllowedMimeTypes = new[] { "application/pdf", "image/png", "image/jpeg" }
        });
        if (result.IsDetermined && result.Payload is not null)
        {
            _linkedFile = result.Payload.FileName;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        ShellUi.OnStateChanged -= HandleShellStateChanged;
        // Note: AppletContext.ClearActiveApplet() is handled by AppletActivationService.Deactivate
        // on navigation — NOT here. Disposing before navigation would prevent the unsaved changes guard.
    }
}
