@page "/sample"
@page "/sample/{NodeId}"
@using FAST.Matrix.Contracts.UI
@using FAST.Matrix.Contracts.Overlay
@using FAST.SampleApplet.Applet
@using FAST.Matrix.Contracts.Applets
@inject IShellAppletContext AppletContext
@inject IFastOverlayOrchestrator Overlay
@implements IDisposable

@{
    // ShellUi comes as CascadingParameter from MainLayout — always the correct WASM instance.
    // SelectedNode is set by the Shell when user clicks a tree node.
    var node = ShellUi?.SelectedNode;
}

<PageTitle>Sample Applet — @(node?.Text ?? "No Selection")</PageTitle>

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="@(node?.IconClass ?? "fas fa-circle") mr-2"></i>
                    @if (node is null)
                    {
                        <span class="text-muted">Select a node from the sidebar tree</span>
                    }
                    else
                    {
                        @node.Text
                        <span class="badge badge-secondary ml-2">@node.NodeType</span>
                    }
                </h3>
                @if (_isDirty)
                {
                    <div class="card-tools">
                        <span class="badge badge-warning">
                            <i class="fas fa-exclamation-triangle mr-1"></i>Unsaved Changes
                        </span>
                    </div>
                }
            </div>

            @if (node?.NodeType == "Office")
            {
                <div class="card-body">
                    <div class="form-group">
                        <label>Office Name</label>
                        <input class="form-control"
                               value="@_officeName"
                               @oninput="e => { _officeName = e.Value?.ToString() ?? string.Empty; SetDirty(); }" />
                    </div>
                    <div class="form-group">
                        <label>Address</label>
                        <input class="form-control"
                               value="@_address"
                               @oninput="e => { _address = e.Value?.ToString() ?? string.Empty; SetDirty(); }" />
                    </div>
                    <div class="form-group">
                        <label>Notes</label>
                        <textarea class="form-control" rows="3"
                                  @oninput="e => { _notes = e.Value?.ToString() ?? string.Empty; SetDirty(); }">@_notes</textarea>
                    </div>
                    <div class="mt-3">
                        <button class="btn btn-success btn-sm" @onclick="SaveAsync">
                            <i class="fas fa-save mr-1"></i> Save
                        </button>
                        <button class="btn btn-info btn-sm ml-2" @onclick="LinkFileAsync">
                            <i class="fas fa-folder-open mr-1"></i> Link File
                        </button>
                        @if (!string.IsNullOrEmpty(_linkedFile))
                        {
                            <span class="ml-3 text-muted">
                                <i class="fas fa-paperclip mr-1"></i>@_linkedFile
                            </span>
                        }
                    </div>
                </div>
            }
            else if (node is not null)
            {
                <div class="card-body text-muted">
                    <i class="fas fa-info-circle mr-1"></i>
                    Select an <strong>Office</strong> node to open its edit form.
                </div>
            }
            else
            {
                <div class="card-body">
                    <div style="min-height:120px;display:flex;align-items:center;justify-content:center;flex-direction:column;">
                        <i class="fas fa-mouse-pointer fa-2x text-muted"></i>
                        <p class="text-muted mt-2">Click any node in the sidebar to begin.</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-primary elevation-1"><i class="fas fa-layer-group"></i></span>
            <div class="info-box-content"><span class="info-box-text">Groups</span><span class="info-box-number">2</span></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-info elevation-1"><i class="fas fa-building"></i></span>
            <div class="info-box-content"><span class="info-box-text">Companies</span><span class="info-box-number">3</span></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-success elevation-1"><i class="fas fa-map-marker-alt"></i></span>
            <div class="info-box-content"><span class="info-box-text">Offices</span><span class="info-box-number">5</span></div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? NodeId { get; set; }

    /// <summary>
    /// Cascaded from MainLayout — always the correct WASM IShellUiContext singleton.
    /// When MainLayout re-renders after a node click, OnParametersSet fires here
    /// and we read the new SelectedNode directly. Zero subscriptions needed.
    /// </summary>
    [CascadingParameter]
    public IShellUiContext? ShellUi { get; set; }

    private string _previousNodeId = string.Empty;
    private bool   _isDirty;
    private string _officeName = string.Empty;
    private string _address    = string.Empty;
    private string _notes      = string.Empty;
    private string _linkedFile = string.Empty;

    protected override void OnInitialized()
    {
        Console.WriteLine($"[SW] OnInitialized — Current={AppletActivationServiceLocator.Current?.GetHashCode().ToString() ?? "NULL"}");
        var applet = AppletActivationServiceLocator.Current?.GetApplet<SampleApplet>();
        Console.WriteLine($"[SW] OnInitialized — applet={applet?.GetHashCode().ToString() ?? "NULL"}");
        if (applet is not null)
            AppletContext.SetActiveApplet(applet);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        Console.WriteLine($"[SW] OnAfterRender(firstRender) — Current={AppletActivationServiceLocator.Current?.GetHashCode().ToString() ?? "NULL"}");
        // OnInitialized ran on server-side (Current was null). Re-set on WASM side.
        var applet = AppletActivationServiceLocator.Current?.GetApplet<SampleApplet>();
        Console.WriteLine($"[SW] OnAfterRender(firstRender) — applet={applet?.GetHashCode().ToString() ?? "NULL"}");
        if (applet is not null)
            AppletContext.SetActiveApplet(applet);
    }

    protected override void OnParametersSet()
    {
        var node   = ShellUi?.SelectedNode;
        var nodeId = node?.Id ?? string.Empty;
        Console.WriteLine($"[SW] OnParametersSet — ShellUi={ShellUi?.GetHashCode().ToString() ?? "NULL"} SelectedNode={nodeId} prev={_previousNodeId}");

        if (nodeId == _previousNodeId) return;
        _previousNodeId = nodeId;

        if (node?.NodeType == "Office")
        {
            _officeName = node.Text;
            _address    = node.Metadata.GetValueOrDefault("address", string.Empty);
            _notes      = string.Empty;
            _isDirty    = false;
            AppletActivationServiceLocator.Current?.GetApplet<SampleApplet>()?.MarkClean();
        }
        else
        {
            _officeName = _address = _notes = string.Empty;
            _isDirty    = false;
        }
    }

    private void SetDirty() { _isDirty = true; AppletActivationServiceLocator.Current?.GetApplet<SampleApplet>()?.MarkDirty(); }

    private async Task SaveAsync()
    {
        await Task.Delay(150);
        _isDirty = false;
        AppletActivationServiceLocator.Current?.GetApplet<SampleApplet>()?.MarkClean();
        StateHasChanged();
    }

    private async Task LinkFileAsync()
    {
        var result = await Overlay.InvokeFileManagerAsync(new FileManagerConfiguration
        {
            PanelTitle       = "Select Office Document",
            AllowedMimeTypes = new[] { "application/pdf", "image/png", "image/jpeg" }
        });
        if (result.IsDetermined && result.Payload is not null)
        {
            _linkedFile = result.Payload.FileName;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        AppletContext.ClearActiveApplet();
    }
}
