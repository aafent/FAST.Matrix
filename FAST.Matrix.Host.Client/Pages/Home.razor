@page "/"

<PageTitle>FAST.Matrix — Dashboard</PageTitle>

<div class="row">
    <div class="col-12">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-th-large mr-2"></i>
                    FAST.Matrix Shell
                </h3>
            </div>
            <div class="card-body">
                <p class="mb-1">The application shell is running. Drop an Applet DLL into the <code>/Applets</code> folder and restart to load it.</p>
                <p class="mb-0 text-muted">
                    <small>
                        Manifest available at
                        <a href="/_matrix/manifest.json" target="_blank"><code>/_matrix/manifest.json</code></a>
                    </small>
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-info elevation-1"><i class="fas fa-puzzle-piece"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Applets Loaded</span>
                <span class="info-box-number">1</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-success elevation-1"><i class="fas fa-check-circle"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Shell Status</span>
                <span class="info-box-number">Online</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box">
            <span class="info-box-icon bg-warning elevation-1"><i class="fas fa-cog"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Render Mode</span>
                <span class="info-box-number">Auto</span>
            </div>
        </div>
    </div>
</div>

<div class="row mt-2">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header"><h3 class="card-title"><i class="fas fa-puzzle-piece mr-2"></i>Registered Applets</h3></div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead><tr><th>Name</th><th>Route</th><th></th></tr></thead>
                    <tbody>
                        <tr>
                            <td>Sample Applet</td>
                            <td><code>/sample</code></td>
                            <td><a href="/sample" class="btn btn-xs btn-primary">Open</a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
